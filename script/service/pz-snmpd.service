[Unit]
Description=PZ SNMP Daemon

After=pz-ipcd.service postgresql.service pz-db-ready.service
Requires=pz-ipcd.service
Wants=postgresql.service pz-db-ready.service
PartOf=pretzel.target

[Service]
Type=simple
RuntimeDirectory=pretzel
ExecStart=/opt/pretzel/bin/pz-snmpd

Restart=always
RestartSec=3

LimitNOFILE=65536

StandardOutput=journal
StandardError=journal
SyslogIdentifier=pz-snmpd

[Install]
WantedBy=pretzel.target
