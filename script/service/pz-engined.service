[Unit]
Description=PZ Engine Daemon

After=pz-ipcd.service postgresql.service pz-db-ready.service
Requires=pz-ipcd.service
Wants=postgresql.service pz-db-ready.service
PartOf=pretzel.target

[Service]
Type=simple
RuntimeDirectory=pretzel
ExecStart=/opt/pretzel/bin/pz-engined

Restart=always
RestartSec=3

LimitNOFILE=1048576

StandardOutput=journal
StandardError=journal
SyslogIdentifier=pz-engined

KillSignal=SIGTERM
TimeoutStopSec=10

[Install]
WantedBy=pretzel.target
