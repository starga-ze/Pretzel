  },
  "icmpd": {
    "daemon_name": "pz-icmpd",
    "system": {
      "logger": {
        "name": "pz-icmpd",
        "file": "/var/log/pretzel/icmpd.log"
      }
    },
    "service": {
      "probe": {
        "scan_cidr": "",
        "excluded_ips": ""
      }
    }
  },
  "ipcd": {
    "daemon_name": "pz-ipcd",
    "system": {
      "logger": {
        "name": "pz-ipcd",
        "file": "/var/log/pretzel/ipcd.log"
      }
    },
    "service": {
      "router": {
        "allow_unknown_dst": false
      }
    }
  },
  "mgmtd": {
    "daemon_name": "pz-mgmtd",
    "system": {
      "logger": {
        "name": "pz-mgmtd",
        "file": "/var/log/pretzel/mgmtd.log",
        "max_files": 10
      }
    },
    "service": {
      "http": {
        "listen_address": "0.0.0.0",
        "listen_port": 443,
        "tls_enabled": true,
        "cert_file": "/etc/pretzel/cert/server.crt",
        "key_file": "/etc/pretzel/cert/server.key"
      },
      "database": {
        "host": "127.0.0.1",
        "port": 5432,
        "name": "pretzel",
        "user": "pretzel"
      }
    }
  },
  "scand": {
    "daemon_name": "pz-scand",
    "system": {
      "logger": {
        "name": "pz-scand",
        "file": "/var/log/pretzel/scand.log"
      }
    },
    "service": {
      "scan": {
        "community": "public",
        "v3_devices": []
      }
    }
  },
  "topologyd": {
    "daemon_name": "pz-topologyd",
    "system": {
      "logger": {
        "name": "pz-topologyd",
        "file": "/var/log/pretzel/topologyd.log"
      }
    },
    "service": {}
  },
  "apid": {
    "daemon_name": "pz-apid",
    "system": {
      "logger": {
        "name": "pz-apid",
        "file": "/var/log/pretzel/apid.log"
      }
    },
    "service": {
      "http": {
        "listen_address": "0.0.0.0",
        "listen_port": 8443,
        "tls_enabled": false
      }
    }
  }
}
