{
  "//": "Committed baseline boot config for all pretzel daemons. Safe to commit: it",
  "//secrets": "carries NO secrets. The DB 'database.password' is injected at deploy",
  "//database": "time from PZ_PG_PASSWORD (script/utils.py -> script/start.py); the admin",
  "//admin": "login lives hashed in the local_users table (engined seeds a default and",
  "//admin2": "applies changes), NOT here; SNMP v3 credentials are entered via the mgmtd",
  "//snmp": "web UI at runtime (stored in running_config, not here).",
  "global": {
    "system": {
      "ipc": {
        "socket_path": "/run/pretzel/ipcd.sock",
        "max_connections": 128,
        "max_frame_size": 1048576,
        "rx_buffer_size": 1048576,
        "tx_buffer_size": 1048576,
        "ipc_retry_attempts": 10,
        "ipc_retry_delay_ms": 1000
      },
      "logger": {
        "max_file_size": 5242880,
        "max_files": 100
      }
    },
    "service": {
      "bootstrap": {
        "client_hello_interval_sec": 1,
        "runtime_ready_interval_sec": 1,
        "bootstrap_timeout_sec": 10
      }
    }
  },
  "engined": {
    "daemon_name": "pz-engined",
    "system": {
      "logger": {
        "name": "pz-engined",
        "file": "/var/log/pretzel/engined.log"
      }
    },
    "service": {
      "bootstrap": {
        "sync_request_interval_sec": 1
      },
      "heartbeat": {
        "poll_interval_sec": 5,
        "response_timeout_sec": 2
      },
      "probe": {
        "poll_interval_sec": 30,
        "response_timeout_sec": 20
      },
      "scan": {
        "poll_interval_sec": 60,
        "response_timeout_sec": 30
      },
      "rack": {
        "racks": []
      }
    }
  },
  "authd": {
    "daemon_name": "pz-authd",
    "system": {
      "logger": {
        "name": "pz-authd",
        "file": "/var/log/pretzel/authd.log"
      }
    },
    "service": {
      "auth": {
        "method": "saml",
        "saml": {
          "enabled": true,
          "idp_sso_url": "https://integrator-2719940.okta.com/app/integrator-2719940_pretzel_1/exk14z80dym2GZBVE698/sso/saml",
          "idp_entity_id": "http://www.okta.com/exk14z80dym2GZBVE698",
