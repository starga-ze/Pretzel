          "sp_entity_id": "https://192.168.0.82/saml/metadata",
          "acs_url": "https://192.168.0.82/api/auth/saml/acs",
          "admin_group": "",
          "groups_attr": "groups",
          "email_attr": "",
          "clock_skew_sec": 120
        }
      }
    }
  },
  "icmpd": {
    "daemon_name": "pz-icmpd",
    "system": {
      "logger": {
        "name": "pz-icmpd",
        "file": "/var/log/pretzel/icmpd.log"
      }
    },
    "service": {
      "probe": {
        "batch_size": 32,
        "batch_interval_ms": 20,
        "cycle_interval_sec": 30,
        "reply_idle_timeout_sec": 5,
        "reply_max_wait_timeout_sec": 15
      }
    }
  },
  "ipcd": {
    "daemon_name": "pz-ipcd",
    "system": {
      "logger": {
        "name": "pz-ipcd",
        "file": "/var/log/pretzel/ipcd.log"
      }
    },
    "service": {
      "router": {
        "allow_unknown_dst": false
      }
    }
  },
  "mgmtd": {
    "daemon_name": "pz-mgmtd",
    "system": {
      "logger": {
        "name": "pz-mgmtd",
        "file": "/var/log/pretzel/mgmtd.log",
        "max_files": 10
      }
    },
    "service": {
      "http": {
        "listen_address": "0.0.0.0",
        "listen_port": 443,
        "tls_enabled": true,
        "cert_file": "/etc/pretzel/cert/server.crt",
        "key_file": "/etc/pretzel/cert/server.key"
      },
      "database": {
        "host": "127.0.0.1",
        "port": 5432,
        "name": "pretzel",
        "user": "pretzel"
      }
    }
  },
  "scand": {
    "daemon_name": "pz-scand",
    "system": {
      "logger": {
        "name": "pz-scand",
        "file": "/var/log/pretzel/scand.log"
      }
    },
    "service": {
      "scan": {
        "community": "public",
        "port": 161,
        "timeout_sec": 2,
        "retries": 1,
        "max_concurrent": 10,
        "v2c_probe_timeout_ms": 700,
        "v2c_probe_retries": 0,
        "v3_devices": []
      }
    }
  },
  "topologyd": {
    "daemon_name": "pz-topologyd",
    "system": {
      "logger": {
        "name": "pz-topologyd",
        "file": "/var/log/pretzel/topologyd.log"
      }
    },
    "service": {}
  }
}
