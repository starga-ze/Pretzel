            "socket_path": "/run/pretzel/ipcd.sock",
            "max_connections": 128,
            "max_frame_size": 65536,
            "rx_buffer_size": 65536,
            "tx_buffer_size": 65536
        },
        "router": {
            "allow_unknown_dst": false
        },
        "daemon_map": {
            "ipcd": 1,
            "engined": 2,
            "mgmtd": 3,
            "authd": 4,
            "snmpd": 5,
            "icmpd": 6,
            "topologyd": 7
        },
        "tuning": {
            "ipc_connect": {
                "max_attempts": 10,
                "retry_delay_ms": 500
            }
        }
    },
    "mgmtd": {
