        },
        "tuning": {
            "bootstrap": {
                "client_hello_interval_ms": 1000,
                "runtime_ready_interval_ms": 1000,
                "bootstrap_timeout_ms": 10000
            },
            "probe": {
                "batch_size": 32,
                "batch_interval_ms": 20,
                "cycle_interval_ms": 30000,
                "reply_idle_timeout_ms": 5000,
                "reply_max_wait_timeout_ms": 15000
            },
            "ipc_connect": {
                "max_attempts": 10,
                "retry_delay_ms": 500
            }
        }
    },
    "ipcd": {
        "daemon_name": "pz-ipcd",
        "logger": {
            "name": "pz-ipcd",
            "file": "/var/log/pretzel/ipcd.log",
            "max_file_size": 5242880,
