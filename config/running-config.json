{
    "engined": {
        "daemon_name": "pz-engined",
        "ipc": {
            "max_connections": 128,
            "max_frame_size": 65536,
            "rx_buffer_size": 65536,
            "socket_path": "/run/pretzel/ipcd.sock",
            "tx_buffer_size": 65536
        },
        "logger": {
            "file": "/var/log/pretzel/engined.log",
            "max_file_size": 5242880,
            "max_files": 100,
            "name": "pz-engined"
        },
        "tuning": {
            "bootstrap": {
                "bootstrap_timeout_ms": 10000,
                "client_hello_interval_ms": 1000,
                "sync_request_interval_ms": 1000
            },
            "heartbeat": {
                "poll_interval_ms": 5000,
                "response_timeout_ms": 2000
            },
            "ipc_connect": {
                "max_attempts": 10,
                "retry_delay_ms": 500
            }
        }
    },
    "authd": {
        "daemon_name": "pz-authd",
        "logger": {
            "name": "pz-authd",
            "file": "/var/log/pretzel/authd.log",
            "max_file_size": 5242880,
            "max_files": 100
        },
        "ipc": {
            "socket_path": "/run/pretzel/ipcd.sock",
            "max_connections": 128,
            "max_frame_size": 65536,
            "rx_buffer_size": 65536,
            "tx_buffer_size": 65536
        },
        "tuning": {
            "bootstrap": {
                "client_hello_interval_ms": 1000,
                "runtime_ready_interval_ms": 1000,
                "bootstrap_timeout_ms": 10000
            },
            "ipc_connect": {
                "max_attempts": 10,
                "retry_delay_ms": 500
            }
        }
    },
    "icmpd": {
        "daemon_name": "pz-icmpd",
        "logger": {
            "name": "pz-icmpd",
            "file": "/var/log/pretzel/icmpd.log",
            "max_file_size": 5242880,
