{
    "daemon_name": "nf-mgmtd",

    "logger": {
        "name": "nf-mgmtd",
        "file": "/var/log/nf-nms/mgmtd.log",
        "max_file_size": 5242880,
        "max_files": 10
    },
  
    "ipc": {
        "socket_path": "/run/nf-nms/ipcd.sock",
        "max_connections": 128,
        "max_frame_size": 65536,
        "rx_buffer_size": 65536,
        "tx_buffer_size": 65536
    },
  
    "http": {
        "listen_address": "0.0.0.0",
        "listen_port": 443,
        "tls_enabled": true,
        "cert_file": "/etc/nf-nms/cert/server.crt",
        "key_file": "/etc/nf-nms/cert/server.key"
    },
  
    "admin": {
        "username": "admin",
        "password_hash": "",
        "salt": ""
    }
}
