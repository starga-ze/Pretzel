build/
build-*/
cmake-build-*/

3rd_party/
backup/
tmp/

.vscode/
.idea/

**/__pycache__/
*.pyc
*.pyo
*.pyd

*.swp
*.tar.gz
*.log

*.claude

# Secrets — keep real values out of git (templates / example files are committed).
# The real startup-config.json carries DB/SNMPv3/admin secrets; ship the
# startup-config.example.json template instead.
config/startup-config.json

# TLS private key + cert: generated locally by script/start.py (ensure_certificates).
cert/*.key
cert/*.crt

# Generated/local env files (e.g. /etc copies are outside the repo, but guard any
# in-tree ones such as a developer .env).
.env
*.env
